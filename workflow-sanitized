    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const j = item.json || {};\n\n  const getWriterDraft = (src) => {\n    if (Array.isArray(src.output)) {\n      for (const out of src.output) {\n        if (Array.isArray(out.content)) {\n          for (const c of out.content) {\n            if (typeof c.text === \"string\" && c.text.trim()) {\n              return c.text.trim();\n            }\n          }\n        }\n      }\n    }\n\n    if (typeof src.output_text === \"string\" && src.output_text.trim()) {\n      return src.output_text.trim();\n    }\n\n    if (typeof src.text === \"string\" && src.text.trim()) {\n      return src.text.trim();\n    }\n\n    return \"\";\n  };\n\n  const writerUsage = j.usage || {};\n  const createdAt = Number(j.created_at || 0);\n  const completedAt = Number(j.completed_at || 0);\n\n  const writerRuntimeSeconds =\n    createdAt && completedAt && completedAt >= createdAt\n      ? completedAt - createdAt\n      : null;\n\n  return {\n    json: {\n      task_id: j.task_id || \"\",\n      task_number: Number(j.task_number || 0),\n      task_title: j.task_title || \"\",\n\n      company_name: j.company_name || \"\",\n      content_type: j.content_type || \"\",\n      target_geo: j.target_geo || \"\",\n      contact_phone: j.contact_phone || \"\",\n\n\n      required_word_count: Number(j.required_word_count || 0),\n      selected_keywords: Array.isArray(j.selected_keywords) ? j.selected_keywords : [],\n\n      writer_model: j.model || \"\",\n      writer_created_at: createdAt || null,\n      writer_completed_at: completedAt || null,\n      writer_runtime_seconds: writerRuntimeSeconds,\n\n      writer_input_tokens: Number(writerUsage.input_tokens || 0),\n      writer_output_tokens: Number(writerUsage.output_tokens || 0),\n      writer_reasoning_tokens: Number(writerUsage.output_tokens_details?.reasoning_tokens || 0),\n      writer_total_tokens: Number(writerUsage.total_tokens || 0),\n\n      final_draft: getWriterDraft(j)\n    }\n  };\n})