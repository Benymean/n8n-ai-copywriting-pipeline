f (!parsed.metaDescription) addFailure(\"meta_description_missing\", \"Meta Description is missing.\");\n  if (!parsed.h1) addFailure(\"h1_missing\", \"H1 is missing.\");\n  if (!parsed.intro) addFailure(\"intro_missing\", \"Intro paragraph is missing.\");\n  if (!parsed.cta.body) addFailure(\"cta_missing\", \"CTA body is missing.\");\n\n  if (parsed.metaTitle) {\n    const len = parsed.metaTitle.length;\n    if (len < META_TITLE_MIN || len > META_TITLE_MAX) {\n      addFailure(\"meta_title_length\", `Meta Title is ${len} characters. Required: ${META_TITLE_MIN} to ${META_TITLE_MAX}.`);\n    }\n  }\n\n  if (parsed.metaDescription) {\n    const len = parsed.metaDescription.length;\n    if (len < META_DESCRIPTION_MIN || len > META_DESCRIPTION_MAX) {\n      addFailure(\"meta_description_length\", `Meta Description is ${len} characters. Required: ${META_DESCRIPTION_MIN} to ${META_DESCRIPTION_MAX}.`);\n    }\n  }\n\n  if (parsed.metaTitle && parsed.h1) {\n    if (normaliseForMatch(parsed.metaTitle) !== normaliseForMatch(parsed.h1)) {\n      addFailure(\"meta_title_h1_mismatch\", \"Meta Title and H1 must match exactly.\");\n    }\n  }\n\n  if (companyName && parsed.metaTitle && containsNormalised(parsed.metaTitle, companyName)) {\n    addFailure(\"meta_title_has_company\", \"Meta Title must not include the company name.\");\n  }\n\n  if (companyName && parsed.h1 && containsNormalised(parsed.h1, companyName)) {\n    addFailure(\"h1_has_company\", \"H1 must not include the company name.\");\n  }\n\n  if (companyName && parsed.metaDescription && !containsNormalised(parsed.metaDescription, companyName)) {\n    addFailure(\"meta_description_missing_company\", \"Meta Description must include the company name.\");\n  }\n\n  if (targetGeo && parsed.metaDescription && !hasGeoMatch(parsed.metaDescription, targetGeo)) {\n    addFailure(\"meta_description_missing_geo\", \"Meta Description must include the target geo.\");\n  }\n\n  if (companyName && parsed.intro && !containsNormalised(parsed.intro, companyName)) {\n    addFailure(\"intro_missing_company\", \"Intro must include the company name.\");\n  }\n\n  if (targetGeo && parsed.intro && !hasGeoMatch(parsed.intro, targetGeo)) {\n    addFailure(\"intro_missing_geo\", \"Intro must include the target geo.\");\n  }\n\n  if (parsed.h1 && !isTitleCaseHeading(parsed.h1)) {\n    addFailure(\"h1_not_title_case\", \"H1 must be in Title Case.\");\n  }\n\n  parsed.sections.forEach((section, index) => {\n    if (section.heading && !isTitleCaseHeading(section.heading)) {\n      addFailure(\"h2_not_title_case\", `H2 heading ${index + 1} must be in Title Case.`);\n    }\n  });\n\n  if (parsed.cta.body && !hasContactPagePhrase(parsed.cta.body)) {\n    addFailure(\n      \"cta_missing_contact_phrase\",\n      \"CTA body must include a contact-page style phrase such as 'contact us online', 'visit our contact page', or similar wording.\"\n    );\n  }\n\n  if (contactPhone) {\n    if (!parsed.cta.body || !hasPhone(parsed.cta.body, contactPhone)) {\n      addFailure(\n        \"cta_missing_phone\",\n        \"CTA body must include the phone number when one is provided.\"\n      );\n    }\n\n    const nonCtaText = [\n      parsed.metaTitle,\n      parsed.metaDescription,\n      parsed.h1,\n      parsed.intro,\n      ...parsed.contentSections.map(section => `${section.heading}\\n${section.body}`),\n      parsed.cta.heading,\n    ].join(\"\\n\\n\");\n\n    if (hasPhone(nonCtaText, contactPhone)) {\n      addFailure(\n        \"phone_outside_cta\",\n        \"Phone number must appear in the CTA body only.\"\n      );\n    }\n  }\n\n  if (parsed.outputKeywords.length && !sameKeywordSet(parsed.outputKeywords, selectedKeywords, targetGeo)) {\n    addFailure(\"keywords_used_mismatch\", \"Keywords used line does not match selected_keywords.\");\n  }\n\n  const keywordEntries = buildKeywordEntries(selectedKeywords, targetGeo);\n\n  const publishableParts = [\n    { name: \"Meta Title\", text: parsed.metaTitle },\n    { name: \"Meta Description\", text: parsed.metaDescription },\n    { name: \"H1\", text: parsed.h1 },\n    { name: \"Intro\", text: parsed.intro },\n    ...parsed.contentSections.flatMap((section, index) => ([\n      { name: `H2 ${index + 1} Heading`, text: section.heading },\n      { name: `H2 ${index + 1} Body`, text: section.body },\n    ])),\n    { name: \"CTA Heading\", text: parsed.cta.heading },\n    { name: \"CTA Body\", text: parsed.cta.body },\n  ];\n\n  const perPartKeywordCounts = Object.fromEntries(\n    publishableParts.map(part => [\n      part.name,\n      getKeywordMatchCounts(part.text, keywordEntries),\n    ])\n  );\n\n  const keywordCounts = {};\n\n  for (const keyword of selectedKeywords) {\n    const perPart = Object.fromEntries(\n      publishableParts.map(part => [\n        part.name,\n        perPartKeywordCounts[part.name][keyword] || 0,\n      ])\n    );\n\n    const total = Object.values(perPart).reduce((sum, count) => sum + count, 0);\n\n    keywordCounts[keyword] = {\n      total,\n      per_part: perPart,\n    };\n\n    if (total !== 2) {\n      addFailure(\n        \"keyword_total_count\",\n        `Keyword '${keyword}' appears ${total} times. It must appear exactly 2 times.`\n      );\n    }\n  }\n\n  const metaTitleHits = sumKeywordHits(perPartKeywordCounts[\"Meta Title\"]);\n  if (parsed.metaTitle && metaTitleHits !== 1) {\n    addFailure(\"meta_title_keyword_count\", `Meta Title contains ${metaTitleHits} selected keywords. It must contain exactly 1.`);\n  }\n\n  const metaDescriptionHits = sumKeywordHits(perPartKeywordCounts[\"Meta Description\"]);\n  if (parsed.metaDescription && metaDescriptionHits !== 1) {\n    addFailure(\"meta_description_keyword_count\", `Meta Description contains ${metaDescriptionHits} selected keywords. It must contain exactly 1.`);\n  }\n\n  const h1Hits = sumKeywordHits(perPartKeywordCounts[\"H1\"]);\n  if (parsed.h1 && h1Hits !== 1) {\n    addFailure(\"h1_keyword_count\", `H1 contains ${h1Hits} selected keywords. It must contain exactly 1.`);\n  }\n\n  const introHits = sumKeywordHits(perPartKeywordCounts[\"Intro\"]);\n  if (parsed.intro && introHits !== 1) {\n    addFailure(\"intro_keyword_count\", `Intro contains ${introHits} selected keywords. It must contain exactly 1.`);\n  }\n\n  parsed.contentSections.forEach((section, index) => {\n    const headingCounts = perPartKeywordCounts[`H2 ${index + 1} Heading`];\n    const bodyCounts = perPartKeywordCounts[`H2 ${index + 1} Body`];\n\n    const headingHits = sumKeywordHits(headingCounts);\n    const bodyHits = sumKeywordHits(bodyCounts);\n    const totalHits = headingHits + bodyHits;\n\n    if (headingHits > 1) {\n      addFailure(\n        \"section_heading_keyword_limit\",\n        `Section ${index + 1} heading contains ${headingHits} selected keywords. Max allowed is 1.`\n      );\n    }\n\n    if (bodyHits > 1) {\n      addFailure(\n        \"section_body_keyword_limit\",\n        `Section ${index + 1} body contains ${bodyHits} selected keywords. Max allowed is 1.`\n      );\n    }\n\n    if (totalHits > 2) {\n      addFailure(\n        \"section_total_keyword_limit\",\n        `Section ${index + 1} contains ${totalHits} selected keywords across heading + body. Max allowed is 2.`\n      );\n    }\n  });\n\n  const pass = failures.length === 0;\n\n  const reportLines = [\n    `task_id: ${j.task_id || \"\"}`,\n    `validator_pass: ${pass}`,\n    `writer_model: ${j.writer_model || \"\"}`,\n    `writer_runtime_seconds: ${j.writer_runtime_seconds ?? \"\"}`,\n    `writer_total_tokens: ${Number(j.writer_total_tokens || 0)}`,\n    \"\",\n    `meta_title_char_count: ${parsed.metaTitle.length}`,\n    `meta_description_char_count: ${parsed.metaDescription.length}`,\n    `content_word_count: ${wordCount}`,\n    \"\",\n    \"failures:\",\n    ...(failures.length\n      ? failures.map((failure, index) => `${index + 1}. ${failure.code} -> ${failure.message}`)\n      : [\"none\"]),\n    \"\",\n    \"keyword_counts:\",\n    ...select