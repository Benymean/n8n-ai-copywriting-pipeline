      "parameters": {
        "jsCode": "return items.map(item => {\n  const src = item.json || {};\n\n  let rawText = \"\";\n\n  if (Array.isArray(src.output)) {\n    for (const out of src.output) {\n      if (Array.isArray(out.content)) {\n        for (const c of out.content) {\n          if (typeof c.text === \"string\" && c.text.trim()) {\n            rawText = c.text;\n            break;\n          }\n        }\n      }\n      if (rawText) break;\n    }\n  }\n\n  if (!rawText && typeof src.output_text === \"string\") {\n    rawText = src.output_text;\n  }\n\n  if (!rawText && typeof src.text === \"string\") {\n    rawText = src.text;\n  }\n\n  const cleaned = rawText\n    .replace(/^```json\\s*/i, \"\")\n    .replace(/^```\\s*/i, \"\")\n    .replace(/\\s*```$/i, \"\")\n    .trim();\n\n  let parsed;\n  try {\n    parsed = JSON.parse(cleaned);\n  } catch (error) {\n    throw new Error(\n      `Failed to parse parser JSON for brief_id=${src.brief_id || \"unknown\"} | file=${src.original_attachment_filename || \"unknown\"} | preview=${cleaned.slice(0, 500)}`\n    );\n  }\n\n  const cleanArray = (arr) =>\n    Array.isArray(arr)\n      ? arr.map(v => String(v).trim()).filter(Boolean)\n      : [];\n\n  let contentType = String(parsed.content_type || \"\").trim();\n  contentType = contentType\n    .replace(/\\b\\d+\\s*x\\b/gi, \"\")\n    .replace(/\\bx\\s*\\d+\\b/gi, \"\")\n    .replace(/\\b\\d+\\s+(pages?|posts?|blogs?|articles?)\\b/gi, \"\")\n    .replace(/\\s{2,}/g, \" \")\n    .trim();\n\n  const explicitMaster = cleanArray(parsed.master_keyword_list);\n\n  const taskKeywords = Array.isArray(parsed.tasks)\n    ? parsed.tasks.flatMap(task => cleanArray(task.keywords))\n    : [];\n\n  const seen = new Set();\n  const dedupedTaskKeywords = taskKeywords.filter(keyword => {\n    const key = keyword.toLowerCase();\n    if (seen.has(key)) return false;\n    seen.add(key);\n    return true;\n  });\n\n  const finalMasterKeywordList =\n    explicitMaster.length > 0 ? explicitMaster : dedupedTaskKeywords;\n\n  return {\n    json: {\n        brief_id: src.brief_id || \"\",\n        original_attachment_filename: src.original_attachment_filename || \"\",\n        binary_key: src.binary_key || \"\",\n    \n        content_type: contentType,\n        company_name: parsed.company_name || \"\",\n        contact_phone: parsed.contact_phone || \"\",\n        target_audience: parsed.target_audience || \"\",\n        general_notes: parsed.general_notes || \"\",\n        writing_style: parsed.writing_style || \"\",\n        target_geo: parsed.target_geo || \"\",\n        master_keyword_list: finalMasterKeywordList,\n        master_keyword_source:\n          explicitMaster.length > 0\n            ? \"explicit\"\n            : dedupedTaskKeywords.length > 0\n            ? \"derived_from_tasks\"\n            : \"\",\n        tasks: Array.isArray(parsed.tasks) ? parsed.tasks : [],\n        parser_input_tokens: Number(src.usage?.input_tokens || 0),\n        parser_output_tokens: Number(src.usage?.output_tokens || 0),\n        parser_total_tokens: Number(src.usage?.total_tokens || 0)\n    }\n  };\n});"
