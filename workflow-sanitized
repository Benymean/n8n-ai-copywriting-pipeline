        "jsCode": "function parseTaskId(taskId) {\n  const value = String(taskId || \"\").trim();\n\n  const match = value.match(/^(.*?__attachment_\\d+__)(.*)__task_(\\d+)$/);\n\n  if (!match) {\n    return {\n      brief_batch_id: value.replace(/__task_\\d+$/, \"\"),\n      attachment_stem: value,\n      task_number: 0,\n    };\n  }\n\n  return {\n    brief_batch_id: value.replace(/__task_\\d+$/, \"\"),\n    attachment_stem: match[2],\n    task_number: Number(match[3] || 0),\n  };\n}\n\nfunction cleanFileStem(stem) {\n  return String(stem || \"Draft\")\n    .replace(/\\.[^.]+$/, \"\")\n    .replace(/\\s*\\(\\d+\\)\\s*$/, \"\")\n    .trim();\n}\n\nfunction formatFailures(failures) {\n  const list = Array.isArray(failures) ? failures : [];\n  if (!list.length) return \"\";\n\n  return [\n    \"validator_failures\",\n    ...list.map((failure, index) =>\n      `${index + 1}. ${failure.code || \"failure\"} -> ${failure.message || \"\"}`\n    ),\n    \"\"\n  ].join(\"\\n\");\n}\n\nconst groups = new Map();\n\nfor (const item of items) {\n  const j = item.json || {};\n  const parsed = parseTaskId(j.task_id);\n\n  const groupKey = parsed.brief_batch_id || String(j.task_id || \"\");\n\n  if (!groups.has(groupKey)) {\n    const cleanedStem = cleanFileStem(parsed.attachment_stem);\n\n    groups.set(groupKey, {\n      brief_batch_id: groupKey,\n      output_filename: `${cleanedStem} - Draft`,\n      source_attachment_stem: parsed.attachment_stem || \"\",\n      tasks: [],\n    });\n  }\n\n  groups.get(groupKey).tasks.push({\n    task_id: j.task_id || \"\",\n    task_number: Number(j.task_number || parsed.task_number || 0),\n    task_title: String(j.task_title || \"\").trim(),\n    validator_failures: Array.isArray(j.validator_failures) ? j.validator_failures : [],\n    final_draft: String(j.final_draft || \"\").trim(),\n  });\n}\n\nreturn Array.from(groups.values()).map(group => {\n  group.tasks.sort((a, b) => a.task_number - b.task_number);\n\n  const combined_markdown = group.tasks.map(task => {\n    const parts = [];\n\n    parts.push(`Task ${task.task_number}`);\n    if (task.task_title) {\n      parts.push(`Task Title: ${task.task_title}`);\n    }\n\n    parts.push(\"\");\n\n    const failureBlock = formatFailures(task.validator_failures);\n    if (failureBlock) {\n      parts.push(failureBlock.trimEnd());\n      parts.push(\"\");\n    }\n\n    parts.push(task.final_draft);\n\n    return parts.join(\"\\n\");\n  }).join(\"\\n\\n\\n---\\n\\n\\n\");\n\n  return {\n    json: {\n      brief_batch_id: group.brief_batch_id,\n      output_filename: group.output_filename,\n      task_count: group.tasks.length,\n      combined_markdown,\n    }\n  };\n});\n"
