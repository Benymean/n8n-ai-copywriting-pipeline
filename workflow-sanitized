    {
      "parameters": {
        "jsCode": "const META_TITLE_MIN = 45;\nconst META_TITLE_MAX = 60;\nconst META_DESCRIPTION_MIN = 145;\nconst META_DESCRIPTION_MAX = 160;\n\nconst SMALL_WORDS = new Set([\n  \"a\", \"an\", \"and\", \"as\", \"at\", \"but\", \"by\", \"for\", \"from\",\n  \"in\", \"of\", \"on\", \"or\", \"per\", \"the\", \"to\", \"up\", \"via\", \"vs\", \"with\"\n]);\n\nconst AU_REGION_ALIASES = {\n  vic: [\"vic\", \"victoria\"],\n  nsw: [\"nsw\", \"new south wales\"],\n  qld: [\"qld\", \"queensland\"],\n  sa: [\"sa\", \"south australia\"],\n  wa: [\"wa\", \"western australia\"],\n  tas: [\"tas\", \"tasmania\"],\n  act: [\"act\", \"australian capital territory\"],\n  nt: [\"nt\", \"northern territory\"],\n};\n\nfunction stripCodeFences(value) {\n  return String(value || \"\")\n    .replace(/^```markdown\\s*/i, \"\")\n    .replace(/^```md\\s*/i, \"\")\n    .replace(/^```\\s*/i, \"\")\n    .replace(/\\s*```$/i, \"\")\n    .trim();\n}\n\nfunction normaliseNewlines(value) {\n  return String(value || \"\")\n    .replace(/\\\\r\\\\n/g, \"\\n\")\n    .replace(/\\\\n/g, \"\\n\")\n    .replace(/\\r\\n/g, \"\\n\")\n    .replace(/\\r/g, \"\\n\");\n}\n\nfunction stripLinkUrls(value) {\n  return String(value || \"\").replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, \"$1\");\n}\n\nfunction normaliseForMatch(value) {\n  return stripLinkUrls(String(value || \"\"))\n    .normalize(\"NFKC\")\n    .replace(/[’]/g, \"'\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .toLowerCase();\n}\n\nfunction normaliseGeoValue(value) {\n  return stripLinkUrls(String(value || \"\"))\n    .normalize(\"NFKC\")\n    .replace(/[’]/g, \"'\")\n    .replace(/[(),/-]/g, \" \")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .toLowerCase();\n}\n\nfunction escapeRegExp(value) {\n  return String(value || \"\").replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\");\n}\n\nfunction containsNormalised(haystack, needle) {\n  const h = normaliseForMatch(haystack);\n  const n = normaliseForMatch(needle);\n  return Boolean(h && n && h.includes(n));\n}\n\nfunction isWordChar(char) {\n  return /^[a-z0-9]$/i.test(char || \"\");\n}\n\nfunction countWords(value) {\n  return String(value || \"\")\n    .trim()\n    .split(/\\s+/)\n    .filter(Boolean).length;\n}\n\nfunction uniqueLower(values) {\n  const seen = new Set();\n  const out = [];\n\n  for (const value of values) {\n    const trimmed = String(value || \"\").trim();\n    const key = trimmed.toLowerCase();\n    if (!trimmed || seen.has(key)) continue;\n    seen.add(key);\n    out.push(trimmed);\n  }\n\n  return out;\n}\n\nfunction normalisePhone(value) {\n  return String(value || \"\").replace(/\\D+/g, \"\");\n}\n\nfunction hasPhone(text, phone) {\n  const phoneDigits = normalisePhone(phone);\n  if (!phoneDigits) return false;\n\n  const textDigits = normalisePhone(text);\n  return textDigits.includes(phoneDigits);\n}\n\nfunction hasContactPagePhrase(text) {\n  const t = normaliseForMatch(text);\n\n  return [\n    /\\bcontact us online\\b/,\n    /\\bcontact page\\b/,\n    /\\bvisit (our )?contact page\\b/,\n    /\\bthrough (our )?contact page\\b/,\n    /\\bvia (our )?contact page\\b/,\n    /\\bon (our )?contact page\\b/,\n    /\\bbook (through|via|on) (our )?contact page\\b/,\n    /\\brequest a quote (through|via|on) (our )?contact page\\b/,\n    /\\bget in touch online\\b/,\n    /\\breach out online\\b/,\n    /\\benquire online\\b/,\n    /\\benquire via (our )?contact page\\b/,\n    /\\benquire through (our )?contact page\\b/,\n  ].some((pattern) => pattern.test(t));\n}\n\nfunction isTitleCaseHeading(value) {\n  const words = String(value || \"\")\n    .trim()\n    .split(/\\s+/)\n    .map(word => word.replace(/^[^A-Za-z0-9]+|[^A-Za-z0-9]+$/g, \"\"))\n    .filter(Boolean);\n\n  if (!words.length) return false;\n\n  return words.every((rawWord) => {\n    const parts = rawWord.split(\"-\");\n\n    return parts.every((part) => {\n      if (!part) return true;\n      if (/^\\d+$/.test(part)) return true;\n      if (/^[A-Z0-9&/]+$/.test(part)) return true;\n      if (/^[A-Z][A-Za-z0-9'’]*$/.test(part)) return true;\n      if (/^[a-z][A-Za-z0-9'’]*$/.test(part)) {\n        return SMALL_WORDS.has(part.toLowerCase());\n      }\n      return false;\n    });\n  });\n}\n\nfunction getRegionAliases(region) {\n  const norm = normaliseGeoValue(region);\n  if (!norm) return [];\n\n  for (const variants of Object.values(AU_REGION_ALIASES)) {\n    if (variants.includes(norm)) {\n      return [...new Set(variants)];\n    }\n  }\n\n  return [norm];\n}\n\nfunction looksLikeRegionCode(value) {\n  const raw = String(value || \"\").trim();\n  return /^[A-Z]{2,4}$/.test(raw);\n}\n\nfunction splitTrailingRegion(raw) {\n  const cleaned = String(raw || \"\").trim().replace(/\\s+/g, \" \");\n  if (!cleaned) return { locality: \"\", regions: [] };\n\n  const tokens = cleaned.split(/\\s+/);\n\n  for (let size = Math.min(4, tokens.length - 1); size >= 1; size--) {\n    const tailRaw = tokens.slice(-size).join(\" \");\n    const tailNorm = normaliseGeoValue(tailRaw);\n\n    const isKnownAlias = Object.values(AU_REGION_ALIASES).some(list => list.includes(tailNorm));\n    const isCode = size === 1 && looksLikeRegionCode(tailRaw);\n\n    if (isKnownAlias || isCode) {\n      return {\n        locality: tokens.slice(0, -size).join(\" \").trim(),\n        regions: [tailRaw.trim()],\n      };\n    }\n  }\n\n  return { locality: cleaned, regions: [] };\n}\n\nfunction parseTargetGeo(targetGeo) {\n  const raw = String(targetGeo || \"\").trim();\n  if (!raw) return { locality: \"\", regions: [] };\n\n  const parenRegions = Array.from(raw.matchAll(/\\(([^)]+)\\)/g))\n    .flatMap(match => String(match[1] || \"\").split(/[,/]/))\n    .map(v => v.trim())\n    .filter(Boolean);\n\n  const withoutParens = raw.replace(/\\([^)]*\\)/g, \" \").replace(/\\s+/g, \" \").trim();\n  const parts = withoutParens\n    .split(/\\s*[-,]\\s*/)\n    .map(v => v.trim())\n    .filter(Boolean);\n\n  if (parts.length >= 2) {\n    return {\n      locality: parts[0],\n      regions: [