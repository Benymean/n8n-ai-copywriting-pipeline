andidateTails = new Set();\n\n  const geoVariants = buildGeoVariants(targetGeo)\n    .map(v => String(v).trim())\n    .filter(Boolean)\n    .sort((a, b) => b.length - a.length);\n\n  geoVariants.forEach(v => candidateTails.add(v));\n\n  const safeGeo = String(targetGeo || \"\").trim();\n  if (safeGeo) {\n    candidateTails.add(safeGeo);\n    safeGeo\n      .split(/[-,()/]/)\n      .map(v => v.trim())\n      .filter(Boolean)\n      .forEach(v => candidateTails.add(v));\n  }\n\n  for (let size = 1; size <= Math.min(3, tokens.length - 1); size++) {\n    candidateTails.add(tokens.slice(-size).join(\" \"));\n  }\n\n  const lowerBase = baseKeyword.toLowerCase();\n\n  for (const tail of candidateTails) {\n    const geoTail = String(tail || \"\").trim();\n    if (!geoTail) continue;\n\n    const lowerTail = geoTail.toLowerCase();\n\n    if (lowerBase.endsWith(` in ${lowerTail}`)) {\n      const stem = baseKeyword.slice(0, baseKeyword.length - (`in ${geoTail}`).length).trim();\n      if (stem) {\n        variants.add(`${stem} ${geoTail}`.replace(/\\s+/g, \" \").trim());\n\n        for (const altGeo of geoVariants) {\n          variants.add(`${stem} ${altGeo}`.replace(/\\s+/g, \" \").trim());\n          variants.add(`${stem} in ${altGeo}`.replace(/\\s+/g, \" \").trim());\n        }\n      }\n    }\n\n    if (lowerBase.endsWith(` ${lowerTail}`) && !lowerBase.endsWith(` in ${lowerTail}`)) {\n      const stem = baseKeyword.slice(0, baseKeyword.length - geoTail.length).trim();\n      if (stem) {\n        variants.add(`${stem} in ${geoTail}`.replace(/\\s+/g, \" \").trim());\n\n        for (const altGeo of geoVariants) {\n          variants.add(`${stem} ${altGeo}`.replace(/\\s+/g, \" \").trim());\n          if (!/\\bin$/i.test(stem)) {\n            variants.add(`${stem} in ${altGeo}`.replace(/\\s+/g, \" \").trim());\n          }\n        }\n      }\n    }\n  }\n\n  return [...variants];\n}\n\nfunction keywordEquivalent(a, b, targetGeo) {\n  const aVariants = new Set(buildKeywordVar