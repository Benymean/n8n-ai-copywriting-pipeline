    {
      "parameters": {
        "jsCode": "/* \n1. prefers task-level keywords first\n2. tops up from the master keyword list if task keywords are too few\n3. strips invisible Unicode chars that can break validator matching\n*/\nreturn items.map(item => {\n  const j = item.json || {};\n\n  const INVISIBLE_RE = /[\\u200B-\\u200D\\u2060\\uFEFF]/g;\n\n  const scrub = (value) =>\n    String(value || \"\")\n      .normalize(\"NFKC\")\n      .replace(INVISIBLE_RE, \"\")\n      .replace(/\\s+/g, \" \")\n      .trim();\n\n  const cleanArray = (arr) =>\n    Array.isArray(arr)\n      ? arr.map(scrub).filter(Boolean)\n      : [];\n\n  const dedupe = (arr) => {\n    const seen = new Set();\n    return arr.filter(v => {\n      const key = scrub(v).toLowerCase();\n      if (!key || seen.has(key)) return false;\n      seen.add(key);\n      return true;\n    });\n  };\n\n  const wc = Number(j.required_word_count || 0);\n\n  let targetKeywordCount = 2;\n  if (wc >= 350 && wc < 500) targetKeywordCount = 3;\n  else if (wc >= 500 && wc < 700) targetKeywordCount = 4;\n  else if (wc >= 700) targetKeywordCount = 5;\n\n  const taskKeywords = dedupe(cleanArray(j.keywords));\n  const masterKeywords = dedupe(cleanArray(j.master_keyword_list));\n\n  const taskKeywordSet = new Set(taskKeywords.map(k => k.toLowerCase()));\n\n  const combinedPool = dedupe([\n    ...taskKeywords,\n    ...masterKeywords.filter(k => !taskKeywordSet.has(k.toLowerCase()))\n  ]);\n\n  const selectedKeywords = combinedPool.slice(0, targetKeywordCount);\n\n  return {\n    json: {\n      ...j,\n      keywords: taskKeywords,\n      master_keyword_list: masterKeywords,\n      target_keyword_count: targetKeywordCount,\n      selected_keywords: selectedKeywords\n    }\n  };\n});\n"
